# Kopiere diese Datei als .env und fülle die Werte aus
# cp .env.example .env

# MongoDB-Verbindungsstring (lokal oder MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/sozialapp

# JWT-Geheimschlüssel (starken Zufallswert wählen)
JWT_SECRET=HIER_EINEN_SICHEREN_GEHEIMSCHLUESSEL_EINSETZEN

# Anthropic API-Schlüssel für Claude KI-Assistent
# Kostenloses Konto: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-DEIN_SCHLUESSEL_HIER

# Server-Port (Standard: 5000)
PORT=5000
