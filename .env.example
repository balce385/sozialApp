# -------------------------------------------------------
# Umgebungsvariablen für SozialApp
# Diese Datei NICHT committen – nur als Vorlage!
# Werte bei IONOS unter: Hosting > App > Umgebungsvariablen eintragen
# -------------------------------------------------------

# PORT wird von IONOS automatisch gesetzt – hier nicht ändern
# PORT=5000

# MongoDB Atlas Verbindung
# Kostenloser Cluster: https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://<benutzer>:<passwort>@cluster0.xxxxx.mongodb.net/sozialapp?retryWrites=true&w=majority

# JWT-Schlüssel (mindestens 32 zufällige Zeichen)
JWT_SECRET=dein-langer-geheimer-schluessel-hier-eintragen

# Produktionsmodus
NODE_ENV=production
